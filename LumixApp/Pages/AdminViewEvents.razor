@page "/AdminViewEvents"
@inject IJSRuntime JS
@inject NavigationManager Nav
@using LumixApp.Models

<PageTitle>Manage Events - Admin</PageTitle>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: #002147;">Manage Events</h2>
            <p class="text-muted">Create, edit, or remove campus events.</p>
        </div>
        <button class="btn btn-primary shadow-sm" @onclick='()=> Nav.NavigateTo("/ManageEvents")'>
            <i class="bi bi-plus-circle me-1"></i> Add New Event 
        </button>
    </div>
    
    @if(isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Fetching events...</p>
        </div>
    }
    else if (!events.Any())
    {
        <div class="alert alert-info border-0 shadow-sm text-center py-5">
            <i class="bi bi-calendar-x fs-1 mb-3 d-block text-primary"></i>
            <h4>No Events Found</h4>
            <p>Click "Add New Event" to create the first event.</p>
        </div>
    }
    else
    {
        <div class="table-responsive bg-white shadow-sm rounded">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 100px;">Cover</th>
                        <th>Event Title</th>
                        <th>Date & Time</th>
                        <th>Location</th>
                        <th>Joining Code</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in events)
                    {
                        <tr>
                            <td>
                                @if(!string.IsNullOrEmpty(item.Cover))
                                {
                                    <img src="@item.Cover" class="rounded object-fit-cover" style="width: 80px; height: 50px;" alt="Cover" />
                                }
                                else
                                {
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center text-secondary" style="width: 80px; height: 50px;">
                                        <i class="bi bi-image"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-bold">@item.Title</td>
                            <td><i class="bi bi-calendar-event me-2 text-muted"></i>@item.Date</td>
                            <td><i class="bi bi-geo-alt me-2 text-muted"></i>@item.Location</td>
                            <td><span class="badge bg-dark">@(item.JoiningCode ?? "Not Set")</span></td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-2" @onclick="()=>NavigateToEdit(item.Id)">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="()=>ConfirmDelete(item.Id)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if(!string.IsNullOrEmpty(statusMessage))
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast show align-items-center text-bg-warning border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    @statusMessage
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick='() => statusMessage = ""'></button>
            </div>
        </div>
    </div>
}

@code {
    private List<EventViewModel> events = new();
    private bool isLoading = true;
    string statusMessage = "";
    
    protected override async Task OnInitializedAsync()
    {
        var user = await JS.InvokeAsync<AuthUser>("firebaseAuth.getUser");
        if (user == null || !user.Email.Equals("admin@lumix.edu", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/Login");
            return;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            events = await JS.InvokeAsync<List<EventViewModel>>("firebaseInterop.getEvents");
        }
        catch (Exception ex)
        {
            statusMessage = "Error connecting to database: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateToEdit(string id) => Nav.NavigateTo($"/ManageEvents/{id}");

    public class EventViewModel : Event { public string Id { get; set; } }
    public class AuthUser { public string Email { get; set; } }

    private async Task ConfirmDelete(string id)
    {
        if(await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this event? This action cannot be undone."))
        {
            statusMessage = "";
            try
            {
                await JS.InvokeVoidAsync("firebaseInterop.deleteEvent", id);
                await LoadData();
            }
            catch (Exception ex)
            {
                statusMessage = "Error deleting event: " + ex.Message;
            }
        }
    }
}
