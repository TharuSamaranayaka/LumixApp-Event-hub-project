@page "/Home"
@page "/"
@inject IJSRuntime JS
@inject NavigationManager Nav
@using LumixApp.Models

<PageTitle>Dashboard - Lumix Digital Events</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="text-primary fw-bold" style="color: #002147 !important;">Welcome to Lumix Events!</h1>
            <p class="text-muted">Discover and register for campus events.</p>
        </div>
        <div class="col-lg-6 mt-3 mt-lg-0">
            <div class="input-group shadow-sm border rounded-pill" style="overflow: hidden;">
                <span class="input-group-text bg-white border-0 py-2 ps-4">
                    <i class="bi bi-search text-primary fs-5"></i>
                </span>
                <input type="text" class="form-control border-0 py-2" 
                       placeholder="Find events (e.g. Art, Hackathon...)" 
                       @bind="searchText" @bind:event="oninput"
                       style="box-shadow: none; font-size: 1rem;" />
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center my-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Loading your dashboard...</p>
        </div>
    }
    else
    {
        <div class="mb-4">
            <div class="btn-group shadow-sm p-1 bg-white rounded-pill" role="group" style="border: 1px solid #eee;">
                <button type="button" class="btn btn-sm rounded-pill px-4 @(filterType == "All" ? "btn-primary" : "btn-light")" @onclick='() => SetFilter("All")'>All</button>
                <button type="button" class="btn btn-sm rounded-pill px-4 @(filterType == "Upcoming" ? "btn-primary" : "btn-light")" @onclick='() => SetFilter("Upcoming")'>Upcoming</button>
                <button type="button" class="btn btn-sm rounded-pill px-4 @(filterType == "Ongoing" ? "btn-primary" : "btn-light")" @onclick='() => SetFilter("Ongoing")'>Ongoing</button>
            </div>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
            <h3 class="mb-3 mb-md-0 fw-bold" style="color: #333;">@GetDisplayTitle()</h3>
            <a href="/ViewEvents" class="btn btn-outline-primary shadow-sm" style="border-radius: 50px; padding: 6px 20px; font-weight: 500; transition: all 0.3s;">
                Browse All Events <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
        
        @if (!FilteredEvents.Any())
        {
            <div class="alert alert-info py-4 text-center">
                <i class="bi bi-calendar-x fs-2 d-block mb-2"></i>
                No events found for this category.
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-3 g-4">
                @foreach (var item in (string.IsNullOrWhiteSpace(searchText) ? FilteredEvents.Take(3) : FilteredEvents))
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0" style="transition: transform 0.2s;">
                            @if(!string.IsNullOrEmpty(item.Cover))
                            {
                                <img src="@item.Cover" class="card-img-top object-fit-cover" style="height: 180px;" alt="@item.Title" />
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
                                    <i class="bi bi-image text-secondary fs-1"></i>
                                </div>
                            }
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title fw-bold" style="color: #002147;">@item.Title</h5>
                                <div class="mb-2 text-muted small">
                                    <div><i class="bi bi-calendar me-1"></i> @item.Date</div>
                                    <div><i class="bi bi-geo-alt me-1"></i> @item.Location</div>
                                </div>
                                <p class="card-text text-truncate-3 small flex-grow-1">@item.Description</p>
                                <button class="btn w-100 mt-3 text-white fw-bold" style="background-color: #800000;" @onclick="()=> NavigateToDetails(item.Id)">
                                    View & RSVP
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<style>
    .text-truncate-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .btn-group .btn {
        font-weight: 500;
        transition: all 0.2s;
    }
    .btn-group .btn-primary {
        background-color: #002147;
        border-color: #002147;
    }
</style>

@code {
    private List<EventViewModel> events = new();
    private bool isLoading = true;
    private string searchText = "";
    private string filterType = "Upcoming";

    private IEnumerable<EventViewModel> FilteredEvents
    {
        get
        {
            var today = DateTime.Today;
            var filtered = events.AsEnumerable();

            if (filterType == "Upcoming")
            {
                filtered = filtered.Where(e => DateTime.TryParse(e.Date, out var d) && d > today);
            }
            else if (filterType == "Ongoing")
            {
                filtered = filtered.Where(e => DateTime.TryParse(e.Date, out var d) && d == today);
            }

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                filtered = filtered.Where(e =>
                    (e.Title?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (e.Location?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            return filtered.OrderBy(e => DateTime.TryParse(e.Date, out var d) ? d : DateTime.MaxValue);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            events = await JS.InvokeAsync<List<EventViewModel>>("firebaseInterop.getEvents");
        }
        catch (Exception)
        {
            // Ignore for now
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetFilter(string type) => filterType = type;

    private string GetDisplayTitle()
    {
        return filterType switch
        {
            "Upcoming" => "Upcoming Events",
            "Ongoing" => "Ongoing Events Today",
            _ => "All Events"
        };
    }

    private void NavigateToDetails(string id) => Nav.NavigateTo($"/EventDetails/{id}");



    public class EventViewModel : Event { public string Id { get; set; } }
    
    public class AuthUser
    {
        public string Email { get; set; }
    }
}
