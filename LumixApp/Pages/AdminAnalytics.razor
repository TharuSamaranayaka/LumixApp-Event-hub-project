@page "/AdminAnalytics"
@inject IJSRuntime JS
@inject NavigationManager Nav
@using LumixApp.Models

<PageTitle>Analytics - Lumix Digital Events</PageTitle>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: #002147;">Event Analytics</h2>
            <p class="text-muted">Registration tracking and student feedback analysis.</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Loading analytics...</p>
        </div>
    }
    else
    {
        <!-- Registration Tracking -->
        <div class="card shadow-sm border-0 mb-5">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h4 style="color: #800000;"><i class="bi bi-people-fill me-2"></i> Registration Tracking</h4>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Event Title</th>
                                <th>Date</th>
                                <th>Total RSVPs</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!events.Any())
                            {
                                <tr><td colspan="3" class="text-center text-muted">No events currently available.</td></tr>
                            }
                            else
                            {
                                @foreach (var evt in events)
                                {
                                    var count = rsvps.Count(r => r.EventId == evt.Id);
                                    <tr>
                                        <td class="fw-bold">@evt.Title</td>
                                        <td>@evt.Date</td>
                                        <td><span class="badge bg-success fs-6">@count Registrations</span></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Feedback Analytics -->
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h4 style="color: #800000;"><i class="bi bi-chat-left-text-fill me-2"></i> Feedback Analytics</h4>
            </div>
            <div class="card-body">
                @if (!feedbackList.Any())
                {
                    <p class="text-muted text-center py-4">No feedback received yet.</p>
                }
                else
                {
                    <div class="row row-cols-1 row-cols-md-2 g-4">
                        @foreach (var fb in feedbackList)
                        {
                            <div class="col">
                                <div class="card h-100 bg-light border-0">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h6 class="fw-bold mb-0">@fb.StudentName</h6>
                                            <div class="text-warning">
                                                @for (int i = 0; i < fb.Rating; i++) { <i class="bi bi-star-fill"></i> }
                                                @for (int i = fb.Rating; i < 5; i++) { <i class="bi bi-star"></i> }
                                            </div>
                                        </div>
                                        <p class="text-muted small mb-0">" @fb.Experience "</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<EventViewModel> events = new();
    private List<RSVPViewModel> rsvps = new();
    private List<FeedbackViewModel> feedbackList = new();

    protected override async Task OnInitializedAsync()
    {
        var user = await JS.InvokeAsync<AuthUser>("firebaseAuth.getUser");
        if (user == null || !user.Email.Equals("admin@lumix.edu", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/Login");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            events = await JS.InvokeAsync<List<EventViewModel>>("firebaseInterop.getEvents");
            rsvps = await JS.InvokeAsync<List<RSVPViewModel>>("firebaseInterop.getAllRSVPs");
            feedbackList = await JS.InvokeAsync<List<FeedbackViewModel>>("firebaseInterop.getAllFeedback");
        }
        catch { }
        finally
        {
            isLoading = false;
        }
    }

    public class EventViewModel : Event { public string Id { get; set; } }
    public class RSVPViewModel : RSVP { public string Id { get; set; } }
    public class FeedbackViewModel : Feedback { public string Id { get; set; } }
    public class AuthUser { public string Email { get; set; } }
}
